from arduino import delay_ms, digital_out, led_builtin, mode_output, pin_mode, uart_begin

class PlainCounter:
    value: i32

class FancyCounter:
    value: i32

    def __str__(self) -> String:
        return "FancyCounter(" + str(self.value) + ")"

uart_begin(115200)
pin_mode(led_builtin(), mode_output())

let plain: PlainCounter = PlainCounter(value=5)
let fancy: FancyCounter = FancyCounter(value=8)

while true:
    digital_out(led_builtin(), true)
    println("Rune AVR object string test")
    print("plain = ")
    println(plain)
    print("fancy = ")
    println(fancy)
    println("----")
    delay_ms(120)
    digital_out(led_builtin(), false)
    delay_ms(120)
