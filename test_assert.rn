def divide(a: i64, b: i64) -> i64:
    assert b != 0, "divisor cannot be zero"
    return a / b

def clamp(val: i64, lo: i64, hi: i64) -> i64:
    assert lo <= hi, "lo must be <= hi"
    if val < lo:
        return lo
    if val > hi:
        return hi
    return val

def main() -> i32:
    println(divide(10, 2))
    println(clamp(5, 0, 10))
    println(clamp(-3, 0, 10))
    println(clamp(15, 0, 10))

    let x: i64 = 42
    assert x > 0
    println(x)

    return 0
