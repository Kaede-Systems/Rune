def grade(score: i64) -> String:
    match score:
        case 5:
            return "A"
        case 4:
            return "B"
        case 3:
            return "C"
        case _:
            return "F"

def day_name(n: i64) -> String:
    match n:
        case 0:
            return "Monday"
        case 1:
            return "Tuesday"
        case 2:
            return "Wednesday"
        case 3:
            return "Thursday"
        case 4:
            return "Friday"
        case _:
            return "Weekend"

def main() -> i32:
    println(grade(5))
    println(grade(4))
    println(grade(3))
    println(grade(1))

    for i in range(6):
        println(day_name(i))

    return 0
