from arduino import delay_ms, digital_out, led_builtin, mode_output, pin_mode, uart_begin

class Counter:
    value: i32

    def __str__(self) -> String:
        return "Counter(" + str(self.value) + ")"

uart_begin(115200)
pin_mode(led_builtin(), mode_output())

let counter: Counter = Counter(value=5)

while true:
    digital_out(led_builtin(), true)
    println("nested str test")
    println(str(counter))
    delay_ms(120)
    digital_out(led_builtin(), false)
    delay_ms(120)
