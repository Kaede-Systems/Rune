def main() -> i32:
    let s: String = "Hello, World!"

    let n: i64 = s.len()
    println(n)

    let up: String = s.upper()
    println(up)

    let lo: String = s.lower()
    println(lo)

    let has: bool = s.contains("World")
    println(has)

    let sw: bool = s.starts_with("Hello")
    println(sw)

    let ew: bool = s.ends_with("!")
    println(ew)

    let r: String = s.replace("World", "Rune")
    println(r)

    let stripped: String = "  hello  ".strip()
    println(stripped)

    return 0
