def main() -> i32:
    let a: i64 = 0b1100
    let b: i64 = 0b1010

    let and_result: i64 = a & b
    let or_result: i64 = a | b
    let xor_result: i64 = a ^ b
    let not_result: i64 = ~a
    let shl_result: i64 = a << 1
    let shr_result: i64 = a >> 1

    println(and_result)
    println(or_result)
    println(xor_result)
    println(shl_result)
    println(shr_result)

    let hex: i64 = 0xFF
    let oct: i64 = 0o17
    let bin: i64 = 0b11001100
    let sep: i64 = 1_000_000

    println(hex)
    println(oct)
    println(bin)
    println(sep)

    return 0
