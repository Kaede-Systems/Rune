    return __rune_builtin_arduino_uart_read_byte()

def uart_read_byte_timeout(timeout_ms: i64) -> i64:
    if timeout_ms <= 0:
        if uart_available() > 0:
            return uart_read_byte()
        return -1
    let deadline: i64 = millis() + timeout_ms
    while millis() < deadline:
        if uart_available() > 0:
            return uart_read_byte()
        delay_ms(1)
    return -1

def uart_peek_byte() -> i64:
    return __rune_builtin_arduino_uart_peek_byte()

