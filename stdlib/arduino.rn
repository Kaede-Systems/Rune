    return

class UartPort:
    baud: i64

    def begin(self) -> unit:
        uart_begin(self.baud)
        return

    def available(self) -> i64:
        return uart_available()

    def read_byte(self) -> i64:
        return uart_read_byte()

    def read_byte_timeout(self, timeout_ms: i64) -> i64:
        return uart_read_byte_timeout(timeout_ms)

    def peek_byte(self) -> i64:
        return uart_peek_byte()

    def write_byte(self, value: i64) -> unit:
        uart_write_byte(value)
        return

    def write(self, text: String) -> unit:
        uart_write(text)
        return

    def write_line(self, text: String) -> unit:
        uart_write_line(text)
        return

    def flush(self) -> unit:
        uart_flush()
        return

