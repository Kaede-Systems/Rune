def servo_pulse_for_angle(angle: i64, min_us: i64, max_us: i64) -> i64:
    let clamped: i64 = clamp_i64(angle, 0, 180)
    return map_range(clamped, 0, 180, min_us, max_us)

def servo_write_calibrated(pin: i64, angle: i64, min_us: i64, max_us: i64) -> unit:
    servo_write_us(pin, servo_pulse_for_angle(angle, min_us, max_us))
    return

