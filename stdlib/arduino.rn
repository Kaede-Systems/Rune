    __rune_builtin_arduino_digital_write(pin, value)
    return

def digital_read(pin: i64) -> bool:
    return __rune_builtin_arduino_digital_read(pin)

def analog_write(pin: i64, value: i64) -> unit:
    __rune_builtin_arduino_analog_write(pin, value)
    return

def analog_read(pin: i64) -> i64:
    return __rune_builtin_arduino_analog_read(pin)

def analog_in(channel: i64) -> i64:
    return analog_read(channel)

def clamp_i64(value: i64, minimum: i64, maximum: i64) -> i64:
    if value < minimum:
        return minimum
    if value > maximum:
        return maximum
    return value

def map_range(value: i64, in_min: i64, in_max: i64, out_min: i64, out_max: i64) -> i64:
    if in_max == in_min:
        return out_min
    return out_min + ((value - in_min) * (out_max - out_min)) / (in_max - in_min)

def pwm_duty_max() -> i64:
    return 255

def analog_reference(mode: i64) -> unit:
    __rune_builtin_arduino_analog_reference(mode)
    return

def pulse_in(pin: i64, state: bool, timeout_us: i64) -> i64:
    return __rune_builtin_arduino_pulse_in(pin, state, timeout_us)

def shift_out(data_pin: i64, clock_pin: i64, bit_order: i64, value: i64) -> unit:
    __rune_builtin_arduino_shift_out(data_pin, clock_pin, bit_order, value)
    return

def shift_in(data_pin: i64, clock_pin: i64, bit_order: i64) -> i64:
    return __rune_builtin_arduino_shift_in(data_pin, clock_pin, bit_order)

def spi_begin(sck_pin: i64, mosi_pin: i64, miso_pin: i64) -> unit:
    pin_mode(sck_pin, mode_output())
    pin_mode(mosi_pin, mode_output())
    pin_mode(miso_pin, mode_input())
    digital_write(sck_pin, false)
    return

def i2c_begin(scl_pin: i64, sda_pin: i64) -> unit:
    pin_mode(scl_pin, mode_input_pullup())
    pin_mode(sda_pin, mode_input_pullup())
    return

def i2c_start(scl_pin: i64, sda_pin: i64) -> unit:
    pin_mode(sda_pin, mode_input_pullup())
    pin_mode(scl_pin, mode_input_pullup())
    delay_us(4)
    pin_mode(sda_pin, mode_output())
    digital_write(sda_pin, false)
    delay_us(4)
    pin_mode(scl_pin, mode_output())
    digital_write(scl_pin, false)
    delay_us(4)
    return

def i2c_stop(scl_pin: i64, sda_pin: i64) -> unit:
    pin_mode(sda_pin, mode_output())
    digital_write(sda_pin, false)
    delay_us(4)
    pin_mode(scl_pin, mode_input_pullup())
    delay_us(4)
    pin_mode(sda_pin, mode_input_pullup())
    delay_us(4)
    return

def i2c_write_byte(scl_pin: i64, sda_pin: i64, value: i64) -> bool:
    let divisor: i64 = 128
    while divisor > 0:
        if ((value / divisor) % 2) != 0:
            pin_mode(sda_pin, mode_input_pullup())
        else:
            pin_mode(sda_pin, mode_output())
            digital_write(sda_pin, false)
        delay_us(4)
        pin_mode(scl_pin, mode_input_pullup())
        delay_us(4)
        pin_mode(scl_pin, mode_output())
        digital_write(scl_pin, false)
        delay_us(4)
        divisor = divisor / 2
    pin_mode(sda_pin, mode_input_pullup())
    delay_us(4)
    pin_mode(scl_pin, mode_input_pullup())
    delay_us(4)
    let ack: bool = not digital_read(sda_pin)
    pin_mode(scl_pin, mode_output())
    digital_write(scl_pin, false)
    delay_us(4)
    return ack

def i2c_read_byte(scl_pin: i64, sda_pin: i64, ack: bool) -> i64:
    let received: i64 = 0
    let count: i64 = 0
    pin_mode(sda_pin, mode_input_pullup())
    while count < 8:
        received = received * 2
        pin_mode(scl_pin, mode_input_pullup())
        delay_us(4)
        if digital_read(sda_pin):
            received = received + 1
        pin_mode(scl_pin, mode_output())
        digital_write(scl_pin, false)
        delay_us(4)
        count = count + 1
    if ack:
        pin_mode(sda_pin, mode_output())
        digital_write(sda_pin, false)
    else:
        pin_mode(sda_pin, mode_input_pullup())
    delay_us(4)
    pin_mode(scl_pin, mode_input_pullup())
    delay_us(4)
    pin_mode(scl_pin, mode_output())
    digital_write(scl_pin, false)
    pin_mode(sda_pin, mode_input_pullup())
    delay_us(4)
    return received

